AUTH_HOST=auth.example.com
# No bot token — user OAuth (identify + guilds.members.read) only. See docs/discord-setup.md
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_GUILD_ID=
# Must be a normal (non-managed) role you created and assigned to yourself.
BOOTSTRAP_ADMIN_ROLE_ID=
DATABASE_URL=postgres://discord_auth:discord_auth@localhost:5432/discord_auth?sslmode=disable
SESSION_TTL=1800
MAPPING_CACHE_TTL=30
ADMIN_GROUP=admin

# REQUIRED for multi-host (auth.example.com + app.example.com).
# Shared parent domain so CSRF + session cookies work across hosts.
# Example: AUTH_HOST=auth.example.com protecting app.example.com → COOKIE_DOMAIN=.example.com
COOKIE_DOMAIN=.example.com

# Set true ONLY if AUTH_HOST is the sole protected host (host-only __Host- cookies).
# Mutually exclusive with COOKIE_DOMAIN.
SINGLE_HOST=false

HEADER_USER=X-Auth-User
HEADER_GROUPS=X-Auth-Groups
LISTEN_ADDR=:4181
